# Required
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/sales_tracker
ANTHROPIC_API_KEY=sk-ant-...

# Optional
RESEND_API_KEY=re_...
APP_PASSWORD=your-demo-password
APP_URL=http://localhost:3000

# Docker Compose
DB_PASSWORD=changeme

# Google Sheets Auto-Fill (optional — see README)
# Base64-encoded service account JSON:
#   base64 -i path/to/service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=
# Shared secret used by /api/cron/sync-sheet (Bearer token).
# Generate: openssl rand -hex 32
CRON_SECRET=
