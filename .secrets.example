# act reads this file with `--secret-file .secrets` (copy to `.secrets` which is
# gitignored). Only populate what the workflows you'll run locally need:
#
# - ci.yml            → no secrets needed (build-only)
# - claude-review.yml → ANTHROPIC_API_KEY
# - security.yml      → no secrets needed
# - deploy.yml        → DON'T run locally (prod)
# - health-watch.yml  → DON'T run locally (external probe)

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional — deploy secrets, never needed for local CI runs
# DEPLOY_SSH_KEY=
# DEPLOY_HOST=
# DEPLOY_USER=
# APP_URL=
# CRON_SECRET=
